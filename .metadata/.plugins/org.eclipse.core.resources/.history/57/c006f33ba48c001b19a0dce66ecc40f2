#include "UartPacket.h"

uint8_t create_checksum(uint8_t rw, uint8_t id, uint8_t data){
	uint8_t checksum_buf;
	uint8_t buf[3];

	buf[0] = ((rw << 3) & 0x08) | (id & 0x07);
	buf[1] = (data >> 4) & 0x0F;
	buf[2] = (data & 0x0F);

	checksum_buf = buf[0] + buf[1] + buf[2];
	checksum_buf = (~checksum_buf + 1) & 0x0F;

	return checksum_buf;
}

uint8_t check_checksum(packet_16bit packet){
	uint8_t buf[4];

	buf[0] = (packet.R >> 12) &0x0F;
	buf[1] = (packet.R >> 8) &0x0F;
}

